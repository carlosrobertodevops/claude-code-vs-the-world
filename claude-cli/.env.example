# Database
POSTGRES_USER="aquawash"
POSTGRES_PASSWORD="aquawash123"
POSTGRES_DB="aquawash"
POSTGRES_PORT="5436"
DATABASE_URL="postgresql://aquawash:aquawash123@localhost:5436/aquawash?schema=public"
DATABASE_URL_DOCKER="postgresql://aquawash:aquawash123@db:5432/aquawash?schema=public"

# NextAuth
AUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
