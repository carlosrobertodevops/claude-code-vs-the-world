# MinIO (S3-compatible storage) - Production
MINIO_ENDPOINT="localhost"
MINIO_ENDPOINT_DOCKER="minio"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="change-me-minio-user"
MINIO_SECRET_KEY="change-me-minio-secret"
MINIO_BUCKET="aquaflow"
MINIO_USE_SSL="false"

# Storage mode: "local" or "s3"
STORAGE_MODE="local"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
