# Database
DATABASE_URL="postgresql://aquaflow:aquaflow@localhost:5435/aquaflow?schema=public"

# NextAuth
AUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# MinIO (S3-compatible storage) - Production
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="aquaflow"
MINIO_USE_SSL="false"

# Storage mode: "local" or "s3"
STORAGE_MODE="local"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
