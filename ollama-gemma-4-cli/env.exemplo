# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=brilhosaas
DATABASE_URL="postgresql://postgres:postgres@db:5432/brilhosaas"

# NextAuth
NEXTAUTH_SECRET="brilhosaas_secret_$(openssl rand -base64 32)"
NEXTAUTH_URL="http://localhost:3000"

# MinIO / S3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="brilhosaas-uploads"
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Project
PROJECT_NAME="BrilhoSaaS"
